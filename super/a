<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Criar Super Admin</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script type="module">
import { createClient } from "https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm";

const supabase = createClient(
  "https://pdajixsoowcyhnjwhgpc.supabase.co",
  "sb_publishable_LatlFlcxk6IchHe3RNmfwA_9Oq4EsZw"
);

window.criarSuperAdmin = async () => {
  const email = document.getElementById("emailAdmin").value.trim().toLowerCase();
  const senha = document.getElementById("senhaAdmin").value.trim();
  const botao = document.getElementById("btnCriar");
  const resultado = document.getElementById("resultado");

  if (!email || !senha) {
    alert("Preencha e-mail e senha");
    return;
  }

  if (senha.length < 6) {
    alert("A senha deve ter pelo menos 6 caracteres");
    return;
  }

  botao.disabled = true;
  botao.textContent = "Criando...";
  resultado.innerHTML = "";

  try {
    let userId = null;

    // 1) tenta criar
    const { data: authData, error: authError } = await supabase.auth.signUp({
      email,
      password: senha
    });

    if (!authError && authData?.user?.id) {
      userId = authData.user.id;
    }

    // 2) se já existir, tenta logar para pegar o id
    if (authError && String(authError.message || "").toLowerCase().includes("already registered")) {
      const { data: loginData, error: loginError } = await supabase.auth.signInWithPassword({
        email,
        password: senha
      });

      if (loginError) {
        throw new Error("Esse usuário já existe. Use a senha correta dele para vinculá-lo como super admin.");
      }

      if (!loginData?.user?.id) {
        throw new Error("Não foi possível obter o ID do usuário existente.");
      }

      userId = loginData.user.id;
    }

    // 3) outros erros
    if (!userId && authError) {
      throw authError;
    }

    // 4) grava em super_admins se ainda não existir
    const { data: existente } = await supabase
      .from("super_admins")
      .select("id")
      .eq("user_id", userId)
      .maybeSingle();

    if (!existente) {
      const { error: superError } = await supabase
        .from("super_admins")
        .insert({
          user_id: userId,
          email: email
        });

      if (superError) throw superError;
    }

    resultado.innerHTML = `
      <div style="margin-top:15px;padding:12px;border-radius:12px;background:#052e16;color:#bbf7d0">
        Super admin vinculado com sucesso!<br><br>
        <b>User ID:</b> ${userId}<br>
        <b>Email:</b> ${email}
      </div>
    `;

    alert("Super admin criado/vinculado com sucesso!");

  } catch (err) {
    console.error("Erro ao criar super admin:", err);
    alert(err.message || "Erro ao criar super admin");
  } finally {
    botao.disabled = false;
    botao.textContent = "Criar Super Admin";
  }
};
</script>

<style>
body{
  margin:0;
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:#020617;
  font-family:Arial;
  color:#fff;
}
.box{
  width:100%;
  max-width:500px;
  background:#0f172a;
  padding:30px;
  border-radius:20px;
  box-sizing:border-box;
}
input,button{
  width:100%;
  padding:14px;
  margin-top:10px;
  border-radius:12px;
  border:none;
  box-sizing:border-box;
}
button{
  background:#22c55e;
  font-weight:bold;
  cursor:pointer;
}
button:disabled{
  opacity:.7;
  cursor:not-allowed;
}
</style>
</head>

<body>
<div class="box">
  <h2>👑 Criar Super Admin</h2>
  <input id="emailAdmin" type="email" placeholder="E-mail do super admin">
  <input id="senhaAdmin" type="password" placeholder="Senha">
  <button id="btnCriar" onclick="criarSuperAdmin()">Criar Super Admin</button>
  <div id="resultado"></div>
</div>
</body>
</html>
