<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FF Filmes - Login</title>
  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    :root{
      --bg:#0b1020;
      --bg-2:#11182d;
      --card:rgba(15,23,42,.82);
      --line:rgba(255,255,255,.08);
      --text:#ffffff;
      --muted:#94a3b8;
      --red:#e50914;
      --red-hover:#b20710;
      --green:#22c55e;
      --shadow:0 20px 60px rgba(0,0,0,.45);
    }

    body{
      font-family:Arial, Helvetica, sans-serif;
      color:var(--text);
      background:
        linear-gradient(rgba(2,6,23,.82), rgba(2,6,23,.92)),
        url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat fixed;
      min-height:100vh;
      overflow-x:hidden;
    }

    .overlay{
      min-height:100vh;
      background:
        radial-gradient(circle at top right, rgba(229,9,20,.18), transparent 25%),
        radial-gradient(circle at bottom left, rgba(37,99,235,.18), transparent 25%);
    }

    .topo{
      width:100%;
      padding:22px 28px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      position:sticky;
      top:0;
      z-index:20;
      backdrop-filter:blur(10px);
      background:linear-gradient(to bottom, rgba(2,6,23,.7), rgba(2,6,23,.18));
    }

    .logo{
      font-size:30px;
      font-weight:900;
      letter-spacing:1px;
      color:var(--red);
      text-transform:uppercase;
      text-shadow:0 4px 20px rgba(229,9,20,.25);
    }

    .topo-info{
      color:var(--muted);
      font-size:14px;
    }

    .container{
      width:100%;
      max-width:1280px;
      margin:0 auto;
      padding:28px 20px 50px;
    }

    .hero{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:28px;
      align-items:center;
      min-height:calc(100vh - 110px);
    }

    .hero-texto{
      padding:12px 6px;
    }

    .tag{
      display:inline-block;
      background:rgba(229,9,20,.16);
      color:#fecaca;
      border:1px solid rgba(229,9,20,.25);
      padding:8px 14px;
      border-radius:999px;
      font-size:13px;
      margin-bottom:18px;
      font-weight:700;
    }

    .hero-texto h1{
      font-size:clamp(34px, 6vw, 68px);
      line-height:1.02;
      margin-bottom:16px;
      text-shadow:0 6px 25px rgba(0,0,0,.45);
    }

    .hero-texto p{
      font-size:18px;
      line-height:1.6;
      color:#dbe4f0;
      max-width:640px;
      margin-bottom:24px;
    }

    .hero-botoes{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:28px;
    }

    .btn{
      border:none;
      border-radius:14px;
      padding:14px 18px;
      font-size:15px;
      font-weight:800;
      cursor:pointer;
      transition:.2s ease;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }

    .btn-primary{
      background:var(--red);
      color:#fff;
      box-shadow:0 12px 30px rgba(229,9,20,.28);
    }

    .btn-primary:hover{
      background:var(--red-hover);
      transform:translateY(-2px);
    }

    .btn-secondary{
      background:rgba(255,255,255,.08);
      color:#fff;
      border:1px solid rgba(255,255,255,.1);
    }

    .btn-secondary:hover{
      background:rgba(255,255,255,.14);
      transform:translateY(-2px);
    }

    .destaques{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:14px;
      max-width:760px;
    }

    .mini-card{
      background:rgba(15,23,42,.68);
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      backdrop-filter:blur(12px);
      box-shadow:var(--shadow);
    }

    .mini-card strong{
      display:block;
      font-size:22px;
      margin-bottom:6px;
    }

    .mini-card span{
      color:var(--muted);
      font-size:14px;
    }

    .login-box{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:28px;
      padding:28px;
      box-shadow:var(--shadow);
      backdrop-filter:blur(14px);
      position:relative;
      overflow:hidden;
    }

    .login-box::before{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(135deg, rgba(229,9,20,.16), transparent 30%, transparent 70%, rgba(37,99,235,.14));
      pointer-events:none;
    }

    .login-topo{
      position:relative;
      z-index:1;
      margin-bottom:20px;
    }

    .login-topo h2{
      font-size:30px;
      margin-bottom:8px;
    }

    .login-topo p{
      color:var(--muted);
      line-height:1.5;
      font-size:15px;
    }

    .form{
      position:relative;
      z-index:1;
    }

    .campo{
      margin-bottom:16px;
    }

    .campo label{
      display:block;
      margin-bottom:8px;
      font-size:14px;
      color:#e2e8f0;
      font-weight:700;
    }

    .campo input{
      width:100%;
      border:none;
      outline:none;
      background:rgba(2,6,23,.8);
      color:#fff;
      border:1px solid rgba(255,255,255,.08);
      border-radius:16px;
      padding:15px 14px;
      font-size:15px;
      transition:.2s ease;
    }

    .campo input:focus{
      border-color:rgba(229,9,20,.7);
      box-shadow:0 0 0 4px rgba(229,9,20,.12);
    }

    .linha{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin:8px 0 18px;
      flex-wrap:wrap;
    }

    .check{
      display:flex;
      align-items:center;
      gap:8px;
      color:var(--muted);
      font-size:14px;
    }

    .link{
      color:#fca5a5;
      text-decoration:none;
      font-size:14px;
      font-weight:700;
    }

    .link:hover{
      text-decoration:underline;
    }

    .btn-login{
      width:100%;
      padding:15px;
      border:none;
      border-radius:16px;
      background:linear-gradient(135deg, #e50914, #b20710);
      color:#fff;
      font-size:16px;
      font-weight:900;
      cursor:pointer;
      transition:.2s ease;
      margin-bottom:16px;
    }

    .btn-login:hover{
      transform:translateY(-2px);
      box-shadow:0 18px 35px rgba(229,9,20,.28);
    }

    .login-extra{
      text-align:center;
      color:var(--muted);
      font-size:14px;
    }

    .login-extra a{
      color:#fff;
      font-weight:800;
      text-decoration:none;
    }

    .login-extra a:hover{
      text-decoration:underline;
    }

    .filmes{
      margin-top:30px;
    }

    .filmes h3{
      font-size:26px;
      margin-bottom:16px;
    }

    .grade-filmes{
      display:grid;
      grid-template-columns:repeat(5, minmax(0,1fr));
      gap:16px;
    }

    .filme{
      background:rgba(15,23,42,.75);
      border:1px solid var(--line);
      border-radius:20px;
      overflow:hidden;
      box-shadow:var(--shadow);
      transition:.22s ease;
      backdrop-filter:blur(10px);
    }

    .filme:hover{
      transform:translateY(-6px) scale(1.02);
      border-color:rgba(229,9,20,.3);
    }

    .poster{
      height:240px;
      position:relative;
      background-size:cover;
      background-position:center;
    }

    .poster::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(to top, rgba(2,6,23,.95), rgba(2,6,23,.15));
    }

    .badge{
      position:absolute;
      top:12px;
      left:12px;
      z-index:2;
      background:rgba(229,9,20,.95);
      color:#fff;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:800;
    }

    .play{
      position:absolute;
      right:12px;
      bottom:12px;
      z-index:2;
      width:44px;
      height:44px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      background:rgba(255,255,255,.14);
      border:1px solid rgba(255,255,255,.18);
      backdrop-filter:blur(10px);
      font-size:18px;
    }

    .filme-info{
      padding:14px;
    }

    .filme-info h4{
      font-size:17px;
      margin-bottom:8px;
    }

    .meta{
      color:var(--muted);
      font-size:13px;
      margin-bottom:10px;
    }

    .sinopse{
      color:#dbe4f0;
      font-size:13px;
      line-height:1.5;
      min-height:58px;
    }

    .rodape{
      margin-top:36px;
      text-align:center;
      color:var(--muted);
      font-size:14px;
    }

    @media (max-width:1100px){
      .hero{
        grid-template-columns:1fr;
      }

      .grade-filmes{
        grid-template-columns:repeat(3, minmax(0,1fr));
      }
    }

    @media (max-width:760px){
      .topo{
        padding:18px 16px;
      }

      .container{
        padding:20px 14px 38px;
      }

      .login-box{
        padding:22px 18px;
        border-radius:22px;
      }

      .destaques{
        grid-template-columns:1fr;
      }

      .grade-filmes{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }

      .poster{
        height:210px;
      }
    }

    @media (max-width:480px){
      .hero-texto h1{
        font-size:34px;
      }

      .hero-texto p{
        font-size:16px;
      }

      .grade-filmes{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>
<body>
  <div class="overlay">
    <header class="topo">
      <div class="logo">FF Filmes</div>
      <div class="topo-info">Sua plataforma de filmes e séries</div>
    </header>

    <main class="container">
      <section class="hero">
        <div class="hero-texto">
          <div class="tag">🎬 Lançamentos, ação, romance e muito mais</div>
          <h1>Entre e assista aos filmes mais destacados da plataforma</h1>
          <p>
            Um sistema de filmes com visual premium, banners grandes, catálogo em destaque
            e uma tela de login elegante para impressionar seus clientes.
          </p>

          <div class="hero-botoes">
            <a href="#login" class="btn btn-primary">Entrar agora</a>
            <a href="#catalogo" class="btn btn-secondary">Ver catálogo</a>
          </div>

          <div class="destaques">
            <div class="mini-card">
              <strong>+5.000</strong>
              <span>Filmes e séries</span>
            </div>
            <div class="mini-card">
              <strong>Full HD</strong>
              <span>Qualidade destacada</span>
            </div>
            <div class="mini-card">
              <strong>24h</strong>
              <span>Acesso rápido</span>
            </div>
          </div>
        </div>

        <div class="login-box" id="login">
          <div class="login-topo">
            <h2>Fazer login</h2>
            <p>Entre com seu e-mail e senha para acessar seu catálogo de filmes.</p>
          </div>

          <form class="form" onsubmit="entrar(event)">
            <div class="campo">
              <label for="email">E-mail</label>
              <input type="email" id="email" placeholder="Digite seu e-mail" required>
            </div>

            <div class="campo">
              <label for="senha">Senha</label>
              <input type="password" id="senha" placeholder="Digite sua senha" required>
            </div>

            <div class="linha">
              <label class="check">
                <input type="checkbox">
                <span>Lembrar acesso</span>
              </label>

              <a href="#" class="link">Esqueci minha senha</a>
            </div>

            <button type="submit" class="btn-login">Entrar no sistema</button>

            <div class="login-extra">
              Não tem conta? <a href="#">Criar agora</a>
            </div>
          </form>
        </div>
      </section>

      <section class="filmes" id="catalogo">
        <h3>Filmes em destaque</h3>

        <div class="grade-filmes">
          <div class="filme">
            <div class="poster" style="background-image:url('https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?auto=format&fit=crop&w=800&q=80');">
              <div class="badge">TOP 1</div>
              <div class="play">▶</div>
            </div>
            <div class="filme-info">
              <h4>Noite Final</h4>
              <div class="meta">Ação • 2026 • 2h 08min</div>
              <div class="sinopse">Um ex-agente precisa voltar à ativa para impedir uma operação que ameaça toda a cidade.</div>
            </div>
          </div>

          <div class="filme">
            <div class="poster" style="background-image:url('https://images.unsplash.com/photo-1478720568477-152d9b164e26?auto=format&fit=crop&w=800&q=80');">
              <div class="badge">NOVO</div>
              <div class="play">▶</div>
            </div>
            <div class="filme-info">
              <h4>Horizonte Azul</h4>
              <div class="meta">Ficção • 2026 • 1h 54min</div>
              <div class="sinopse">Uma missão espacial revela um sinal misterioso vindo de um planeta aparentemente desabitado.</div>
            </div>
          </div>

          <div class="filme">
            <div class="poster" style="background-image:url('https://images.unsplash.com/photo-1485846234645-a62644f84728?auto=format&fit=crop&w=800&q=80');">
              <div class="badge">BOMBANDO</div>
              <div class="play">▶</div>
            </div>
            <div class="filme-info">
              <h4>Cidade Sombria</h4>
              <div class="meta">Suspense • 2025 • 2h 01min</div>
              <div class="sinopse">Uma investigadora segue pistas perigosas em uma cidade cheia de segredos e desaparecimentos.</div>
            </div>
          </div>

          <div class="filme">
            <div class="poster" style="background-image:url('https://images.unsplash.com/photo-1440404653325-ab127d49abc1?auto=format&fit=crop&w=800&q=80');">
              <div class="badge">EM ALTA</div>
              <div class="play">▶</div>
            </div>
            <div class="filme-info">
              <h4>Destino de Fogo</h4>
              <div class="meta">Drama • 2025 • 1h 47min</div>
              <div class="sinopse">Em meio a perdas e escolhas difíceis, uma família luta para recomeçar após uma grande tragédia.</div>
            </div>
          </div>

          <div class="filme">
            <div class="poster" style="background-image:url('https://images.unsplash.com/photo-1518998053901-5348d3961a04?auto=format&fit=crop&w=800&q=80');">
              <div class="badge">PREMIUM</div>
              <div class="play">▶</div>
            </div>
            <div class="filme-info">
              <h4>Véu da Lua</h4>
              <div class="meta">Romance • 2026 • 1h 39min</div>
              <div class="sinopse">Dois destinos se cruzam em uma história intensa marcada por reencontros e segredos do passado.</div>
            </div>
          </div>
        </div>
      </section>

      <div class="rodape">
        © 2026 FF Filmes - Tela de login modelo
      </div>
    </main>
  </div>

  <script>
    function entrar(e){
      e.preventDefault();

      const email = document.getElementById('email').value.trim();
      const senha = document.getElementById('senha').value.trim();

      if(!email || !senha){
        alert('Preencha e-mail e senha.');
        return;
      }

      alert('Login enviado com sucesso! Agora você pode ligar isso ao seu sistema real.');
    }
  </script>
</body>
</html>
